@using static Domain.Exemplar
@model IEnumerable<Domain.Exemplar>
@{
    ViewData["Title"] = "Просмотр экземпляров";
    var isAdmin = Context.Session.GetInt32("UserLevel") == 2;
}


<h1>Экземпляры</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>ISBN</th>
            <th>Секция</th>
            <th>Стеллаж</th>
            <th>Цена</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.EditionISBN</td>
                @* <td>@item.Edition</td>  *@
                <td>@item.Section</td>
                <td>@item.Shelf</td>
                <td>@item.Price</td>
                <td>
                    @if (item.Status == ExemplarStatus.InStock)
                    {
                        <span>В наличии</span>
                    }
                    else if (item.Status == ExemplarStatus.Sold)
                    {
                        <span>Продан</span>
                    }
                    else if (item.Status == ExemplarStatus.Defective)
                    {
                        <span>Брак</span>
                    }
                </td>
                @* <td>@item.Status</td> *@
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="edit-btn">Редактировать</a> |
                    @* <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> | *@
                    @if (isAdmin)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="delete-btn">Удалить</a>
                    }
                    
                </td>
            </tr>
        }
    </tbody>
</table>

<button style="width: 200px; margin-left: 10%; margin-top: 20px;">
    <a asp-controller="Exemplars" asp-action="Create">Добавить экземпляр</a>
</button>