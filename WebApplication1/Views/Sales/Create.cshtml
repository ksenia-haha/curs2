@model Sale
@{
    ViewData["Title"] = "Добавление продажи";
    var isAdmin = Context.Session.GetInt32("UserLevel") == 2;
}


<h1>Добавление продажи</h1>

<form method="post" asp-controller="Sales" asp-action="Create" id="saleForm" class="form-input-cont">

    @if (isAdmin)
    {
        <div class="form-input">
            <label asp-for="EmployeeId"></label>
            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeList">
                <option value=""></option>
            </select>
            <span asp-validation-for="EmployeeId"></span>
        </div>
    }
    else
    {
        <input type="hidden" name="EmployeeId" value="@Context.Session.GetInt32("UserId")" />
        <p>Продажу оформляет: @Context.Session.GetString("UserSurname") @Context.Session.GetString("UserName") </p>
    }

    <div class="form-input">
        <label asp-for="ClientId"></label>
        <select asp-for="ClientId" asp-items="ViewBag.ClientList">
            <option value=""></option>
        </select>
        <span asp-validation-for="ClientId"></span>
    </div>

    <h4>Товары</h4>

    <div class="form-group">
        <select name="selectedExemplarIds" class="multichoose" multiple size="8">
            @foreach (var ex in ViewBag.ExemplarList)
            {
                <option value="@ex.Value">@ex.Text</option>
            }
        </select>
        <br />
    </div>

    <input type="submit" value="Оформить продажу" />

</form> 

<script>
function checkClient() {
let input = document.querySelector('[name="ClientId"]');
let value = input.value.trim();
let errorSpan = document.querySelector('[data-valmsg-for="ClientId"]');

if (value === '') {
errorSpan.innerHTML = "Выберите клиента";
errorSpan.style.color = "red";
input.style.border = "2px solid red";
return false;
} else {
errorSpan.innerHTML = "";
input.style.border = "";
return true;
}
}

function checkEmployee() {
let input = document.querySelector('[name="EmployeeId"]');
let value = input.value.trim();
let errorSpan = document.querySelector('[data-valmsg-for="EmployeeId"]');

if (value === '') {
errorSpan.innerHTML = "Выберите сотрудника";
errorSpan.style.color = "red";
input.style.border = "2px solid red";
return false;
} else {
errorSpan.innerHTML = "";
input.style.border = "";
return true;
}
}

function checkProducts() {
let select = document.querySelector('[name="selectedExemplarIds"]');
let selectedOptions = Array.from(select.selectedOptions);
let errorSpan = document.querySelector('[data-valmsg-for="selectedExemplarIds"]');

if (selectedOptions.length === 0) {
if (!errorSpan) {
errorSpan = document.createElement('span');
errorSpan.setAttribute('data-valmsg-for', 'selectedExemplarIds');
errorSpan.setAttribute('data-valmsg-replace', 'true');
select.parentNode.appendChild(errorSpan);
}
errorSpan.innerHTML = "Выберите хотя бы один товар";
errorSpan.style.color = "red";
select.style.border = "2px solid red";
return false;
} else {
if (errorSpan) {
errorSpan.innerHTML = "";
}
select.style.border = "";
return true;
}
}

let form = document.getElementById('saleForm');
form.addEventListener('submit', function(event) {
let isClientIdOk = checkClient();
let isEmployeeIdOk = checkEmployee();
let isProductsOk = checkProducts();

if (!isClientIdOk || !isEmployeeIdOk || !isProductsOk) {
event.preventDefault();
}
});

document.querySelector('[name="ClientId"]').addEventListener('input', checkClient);
document.querySelector('[name="EmployeeId"]').addEventListener('input', checkEmployee);
document.querySelector('[name="selectedExemplarIds"]').addEventListener('change', checkProducts);

</script>