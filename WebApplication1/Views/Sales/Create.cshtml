@model Sale
@{
    ViewData["Title"] = "Просмотр продаж";
}


<h1>Добавление продажи</h1>

<form method="post" asp-controller="Sales" asp-action="Create">
    <div class="form-input">
        <label asp-for="Id"></label>
        <input asp-for="Id" />
        <span asp-validation-for="Id"></span>
    </div>

    <div class="form-input">
        <label asp-for="ClientId"></label>
        <select asp-for="ClientId" asp-items="ViewBag.ClientList">
            <option value=""></option>
        </select>
        <span asp-validation-for="ClientId"></span>
    </div>

    <div class="form-input">
        <label asp-for="EmployeeId"></label>
        <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeList">
            <option value=""></option>
        </select>
        <span asp-validation-for="EmployeeId"></span>
    </div>

    <div class="form-input">
        <label asp-for="Date"></label>
        <input asp-for="Date" />
        <span asp-validation-for="Date"></span>
    </div>

    <div class="form-input">
        <label asp-for="Sum"></label>
        <input asp-for="Sum" />
        <span asp-validation-for="Sum"></span>
    </div>

    <h4>Товары</h4>

    <table>
        <thead>
            <th>Экземпляр</th>
            <th>Цена</th>
            <th></th>
        </thead>
        <tbody>
            <tr>
                <td>
                    <select name="exemlarId">
                        <option value=""></option>
                        @foreach (var ex in ViewBag.ExemplarList)
                            {
                                <option value="@ex.Value">@ex.Text</option>
                            }
                        </select>
                </td>
                <td>

                </td>
                <td>
                    <button>Добавить</button>
                    <button>Удалить</button>
                </td>
            </tr>
        </tbody>
    </table>

    <input type="submit" value="Оформить продажу" />

</form> 