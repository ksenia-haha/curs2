@model IEnumerable<Domain.Sale>
@{
    ViewData["Title"] = "Просмотр продаж";
    var isAdmin = Context.Session.GetInt32("UserLevel") == 2;
}


<h1>Продажи</h1>

<table class="table" id="salesTable">
    <thead>
        <tr>
            <th>ID</th>
            <th>Клиент</th>
            <th>Сотрудник</th>
            <th>Дата</th>
            <th>Сумма</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Client?.Name @item.Client?.Surname</td> 
                <td>@item.Employee?.Name @item.Employee?.Surname</td>
                <td>@item.Date</td>
                <td>@item.Sum</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="edit-btn">Редактировать</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a> | 
                    @if (isAdmin)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="delete-btn">Удалить</a>
                    }
                    
                </td>
            </tr>
        }
    </tbody>
</table>


<button style="width: 200px; margin-left: 10%; margin-top: 20px;">
    <a asp-controller="Sales" asp-action="Create">Добавить продажу</a>
</button>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/saleHub")
    .build();

    connection.on("SaleCreated", (id, clientName, employeeName, date, sum) => {
    const newRow = `
    <tr id="saleRow_${id}">
    <td style="text-align: center;">${id}</td>
    <td class="clientName">${clientName}</td>
    <td class="employeeName">${employeeName}</td>
    <td class="date">${date}</td>
    <td class="sum">${sum}</td>
    <td>
    <a href="/Sales/Edit/${id}">Редактировать</a> |
    <a href="/Sales/Details/${id}">Подробнее</a> |
    <a href="/Sales/Delete/${id}" class="delete-btn" onclick="event.preventDefault(); if(confirm('Удалить?')) fetch(this.href, {method:'POST'});">Удалить</a>
    </td>
    </tr>
    `;
    document.querySelector('#salesTable tbody').insertAdjacentHTML('afterbegin', newRow);
    });

    connection.on("SaleUpdated", (id, clientName, employeeName, date, sum) => {
    const row = document.getElementById(`saleRow_${id}`);
    if (row) {
    row.querySelector('.clientName').textContent = clientName;
    row.querySelector('.employeeName').textContent = employeeName;
    row.querySelector('.date').textContent = date;
    row.querySelector('.sum').textContent = sum;
    }
    });

    connection.on("SaleDeleted", (id) => {
    const row = document.getElementById(`saleRow_${id}`);
    if (row) {
    row.remove();
    }
    });

    document.querySelectorAll('#salesTable tbody tr').forEach(row => {
    const firstCell = row.querySelector('td:first-child');
    if (firstCell) {
    const id = firstCell.textContent.trim();
    row.id = `saleRow_${id}`;
            
    const cells = row.querySelectorAll('td');
    if (cells.length >= 5) {
    cells[0].style.textAlign = 'center';
    cells[1].classList.add('clientName');
    cells[2].classList.add('employeeName');
    cells[3].classList.add('date');
    cells[4].classList.add('sum');
    }
    }
    });

    connection.start();
</script>