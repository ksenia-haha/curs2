@model WebApplication1.Models.Log

<h2 style="text-align:center;">Авторизация</h2>

<form asp-action="Login" asp-controller="Log" method="post" class="auth-form">
    <div>
        <label asp-for="Login"></label>
        <input asp-for="Login" style="margin-left: 10px;" />
        <br />
        <span asp-validation-for="Login"></span>
    </div>
    <div>
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" style="margin-left: 2px;" />
        <br />
        <span asp-validation-for="Password"></span>
    </div>
    <div id="serverError" style="color: red; margin-top: 5px; display: none;"></div>
    <button type="submit">Войти</button>
</form>

<script>
    const form = document.querySelector('form');
    const passwordInput = document.querySelector('[name="Password"]');
    const loginInput = document.querySelector('[name="Login"]');
    const serverErrorDiv = document.getElementById('serverError');

    let passwordErrorSpan = document.querySelector('[data-valmsg-for="Password"]');
    if (!passwordErrorSpan) {
        passwordErrorSpan = document.createElement('span');
        passwordErrorSpan.setAttribute('data-valmsg-for', 'Password');
        passwordInput.parentNode.appendChild(passwordErrorSpan);
    }

    function checkPassword() {
        const password = passwordInput.value;

        if (password === '') {
            passwordErrorSpan.innerHTML = "Введите пароль";
            passwordErrorSpan.style.color = "red";
            passwordInput.style.border = "2px solid red";
            passwordInput.style.backgroundColor = "#ffe6e6";
            return false;
        } else {
            passwordErrorSpan.innerHTML = "";
            passwordInput.style.border = "";
            passwordInput.style.backgroundColor = "";
            return true;
        }
    }

    function checkLogin() {
        const login = loginInput.value;
        let loginErrorSpan = document.querySelector('[data-valmsg-for="Login"]');

        if (!loginErrorSpan) {
            loginErrorSpan = document.createElement('span');
            loginErrorSpan.setAttribute('data-valmsg-for', 'Login');
            loginInput.parentNode.appendChild(loginErrorSpan);
        }

        if (login === '') {
            loginErrorSpan.innerHTML = "Введите логин";
            loginErrorSpan.style.color = "red";
            loginInput.style.border = "2px solid red";
            loginInput.style.backgroundColor = "#ffe6e6";
            return false;
        } else {
            loginErrorSpan.innerHTML = "";
            loginInput.style.border = "";
            loginInput.style.backgroundColor = "";
            return true;
        }
    }

    @if (ViewData.ModelState.ContainsKey("") && ViewData.ModelState[""].Errors.Any())
    {
            <text>
                serverErrorDiv.innerText = '@Html.Raw(ViewData.ModelState[""].Errors.First().ErrorMessage)';
                serverErrorDiv.style.display = "block";
            </text>
    }

    form.addEventListener('submit', function(event) {
        const isLoginOk = checkLogin();
        const isPasswordOk = checkPassword();

        if (!isLoginOk || !isPasswordOk) {
            event.preventDefault();
            serverErrorDiv.style.display = "none";
        }
    });

    passwordInput.addEventListener('input', function() {
        if (passwordInput.value !== '') {
            passwordErrorSpan.innerHTML = "";
            passwordInput.style.border = "";
            passwordInput.style.backgroundColor = "";
            serverErrorDiv.style.display = "none";
        }
    });

    loginInput.addEventListener('input', function() {
        let loginErrorSpan = document.querySelector('[data-valmsg-for="Login"]');
        if (loginInput.value !== '') {
            if (loginErrorSpan) {
                loginErrorSpan.innerHTML = "";
            }
            loginInput.style.border = "";
            loginInput.style.backgroundColor = "";
            serverErrorDiv.style.display = "none";
        }
    });
</script>