@model Employee
@{
    ViewData["Title"] = "Редактировать работника";
}


<h1>@ViewData["Title"]</h1>

<form method="post" asp-controller="Employees" asp-action="Edit" id="employeeForm" class="form-input-cont">
    <input type="hidden" asp-for="Id" />

    <div class="form-input">
        <label asp-for="Surname"></label>
        <input asp-for="Surname" />
        <span asp-validation-for="Surname"></span>
    </div>

    <div class="form-input">
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div class="form-input">
        <label asp-for="Patronymic"></label>
        <input asp-for="Patronymic" />
        <span asp-validation-for="Patronymic"></span>
    </div>

    <div class="form-input">
        <label asp-for="Position"></label>
        <input asp-for="Position" />
        <span asp-validation-for="Position"></span>
    </div>

    <div class="form-input">
        <label asp-for="Login"></label>
        <input asp-for="Login" />
        <span asp-validation-for="Login"></span>
    </div>

    <div class="form-input">
        <label asp-for="Level"></label>
        <input asp-for="Level" />
        <span asp-validation-for="Level"></span>
    </div>

    <input type="submit" value="Обновить" />

</form>

<script>
    function checkSurname()
    {
        let surnameInput = document.querySelector('[name="Surname"]');
        let surname = surnameInput.value.trim();
        let hasDigits = /\d/;

        let errorSpan = document.querySelector('[data-valmsg-for="Surname"]');

        if (surname === '') {
            errorSpan.innerHTML = "Введите фамилию";
            errorSpan.style.color = "red";
            surnameInput.style.border = "2px solid red";
            return false;
        } else if (surname.length < 2) {
            errorSpan.innerHTML = "Фамилия слишком короткая";
            errorSpan.style.color = "red";
            surnameInput.style.border = "2px solid red";
            return false;
        } else if (hasDigits.test(surname)) {
            errorSpan.innerHTML = "Фамилия не может содержать цифры";
            errorSpan.style.color = "red";
            surnameInput.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            surnameInput.style.border = "";
            return true;
        }
    }

    function checkName()
    {
        let nameInput = document.querySelector('[name="Name"]');
        let name = nameInput.value.trim();
        let hasDigits = /\d/;

        let errorSpan = document.querySelector('[data-valmsg-for="Name"]');

        if (name === '') {
            errorSpan.innerHTML = "Введите имя";
            errorSpan.style.color = "red";
            nameInput.style.border = "2px solid red";
            return false;
        } else if (name.length < 2) {
            errorSpan.innerHTML = "Имя слишком короткое";
            errorSpan.style.color = "red";
            nameInput.style.border = "2px solid red";
            return false;
        } else if (hasDigits.test(name)) {
            errorSpan.innerHTML = "Имя не может содержать цифры";
            errorSpan.style.color = "red";
            nameInput.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            nameInput.style.border = "";
            return true;
        }
    }

    function checkPatronymic()
    {
        let patronymicInput = document.querySelector('[name="Patronymic"]');
        let patronymic = patronymicInput.value.trim();
        let hasDigits = /\d/;

        let errorSpan = document.querySelector('[data-valmsg-for="Patronymic"]');

        if (patronymic === '') {
            errorSpan.innerHTML = "";
            patronymicInput.style.border = "";
            return true;
        }

        if (hasDigits.test(patronymic)) {
            errorSpan.innerHTML = "Отчество не может содержать цифры";
            errorSpan.style.color = "red";
            patronymicInput.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            patronymicInput.style.border = "";
            return true;
        }
    }

    function checkPosition() {
        let input = document.querySelector('[name="Position"]');
        let value = input.value.trim();
        let hasDigits = /\d/;
        let errorSpan = document.querySelector('[data-valmsg-for="Position"]');

        if (value === '') {
            errorSpan.innerHTML = "Введите должность";
            errorSpan.style.color = "red";
            input.style.border = "2px solid red";
            return false;
        } else if (hasDigits.test(value)) {
            errorSpan.innerHTML = "Должность не может содержать цифры";
            errorSpan.style.color = "red";
            input.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            input.style.border = "";
            return true;
        }
    }

    function checkLevel() {
        let input = document.querySelector('[name="Level"]');
        let value = input.value.trim();
        let errorSpan = document.querySelector('[data-valmsg-for="Level"]');
        
        if (value === '') {
            errorSpan.innerHTML = "Выберите уровень доступа";
            errorSpan.style.color = "red";
            input.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            input.style.border = "";
            return true;
        }
    }
    
    function checkLogin() {
        let input = document.querySelector('[name="Login"]');
        let value = input.value.trim();
        let errorSpan = document.querySelector('[data-valmsg-for="Login"]');
        
        if (value === '') {
            errorSpan.innerHTML = "Введите логин";
            errorSpan.style.color = "red";
            input.style.border = "2px solid red";
            return false;
        } else if (value.length < 4) {
            errorSpan.innerHTML = "Логин не может быть короче 4 символов";
            errorSpan.style.color = "red";
            input.style.border = "2px solid red";
            return false;
        } else {
            errorSpan.innerHTML = "";
            input.style.border = "";
            return true;
        }
    }
    

     let form = document.getElementById('employeeForm');
        form.addEventListener('submit', function(event) {
        let isSurnameOk = checkSurname();
        let isNameOk = checkName();
        let isPatronymicOk = checkPatronymic();
        let isLoginOk = checkLogin();
        let isPositionOk = checkPosition();
        let isLevelOk = checkLevel();
        
    
        if (!isSurnameOk || !isNameOk || !isLoginOk || !isPositionOk || !isLevelOk || !isPatronymicOk) {
            event.preventDefault();
        }
    });

     document.querySelector('[name="Surname"]').addEventListener('input', checkSurname);
     document.querySelector('[name="Name"]').addEventListener('input', checkName);
     document.querySelector('[name="Patronymic"]').addEventListener('input', checkPatronymic);
     document.querySelector('[name="Position"]').addEventListener('input', checkPosition);
     document.querySelector('[name="Login"]').addEventListener('input', checkLogin);
     document.querySelector('[name="Level"]').addEventListener('input', checkLevel);

</script>