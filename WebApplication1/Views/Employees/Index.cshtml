@model IEnumerable<Domain.Employee>
@{
    ViewData["Title"] = "Сотрудники";
    var isAdmin = Context.Session.GetInt32("UserLevel") == 2;
}


<h1>Сотрудники</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Имя</th>
            <th>Фамилия</th>
            <th>Отчество</th>
            <th>Должность</th>
            <th>Логин</th>
            @* <th>Пароль</th> *@
            <th>Уровень доступа</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Surname</td>
                <td>@item.Name</td>
                <td>@item.Patronymic</td>
                <td>@item.Position</td>
                <td>@item.Login</td>
                @* <td>@item.Password</td> *@
                <td>@item.Level</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="edit-btn">Редактировать</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="edit-btn">Подробнее</a> |
                    @if (isAdmin)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="delete-btn">Удалить</a>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>

<button style="width: 200px; margin-left: 10%; margin-top: 20px;">
    <a asp-controller="Employees" asp-action="Create">Добавить сотрудника</a>
</button>